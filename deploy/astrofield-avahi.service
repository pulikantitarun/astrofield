<?xml version="1.0" standalone="no"?>
<!DOCTYPE service-group SYSTEM "avahi-service.dtd">
<service-group>
  <name replace-wildcards="yes">AstroField on %h</name>
  <service>
    <type>_astrofield._tcp</type>
    <port>8765</port>
    <txt-record>version=1</txt-record>
    <txt-record>path=/api/v1</txt-record>
  </service>
</service-group>
